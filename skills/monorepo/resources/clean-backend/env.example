# App Environment:development| production
# Secret Key: 用于加密会话等，生产环境必须修改为随机密钥
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
APP_ENV=production
SECRET_KEY=cc1369ee1441de830cbba0e5030b8dd912d739f48381e4b3f4c3e064bf46665c

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=test_db

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Tool Execution Configuration
TOOL_REQUEST_TIMEOUT=30
TOOL_MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO

LOG_DIR=logs

LOG_ENABLE_FILE=true

LOG_ENABLE_CONSOLE=true

LOG_MAX_BYTES=10485760

LOG_BACKUP_COUNT=5

# Rate Limiting Configuration

RATE_LIMIT_ENABLED=true

RATE_LIMIT_DEFAULT=60/minute

RATE_LIMIT_STORAGE_URI=memory://

CORS_ORIGINS=*

# Nginx Configuration
ENABLE_HTTPS=true
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Gunicorn Configuration
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30

# Redis Configuration (for Token Verification)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=Tiannai.123456
REDIS_DECODE_RESPONSES=true
REDIS_TOKEN_KEY_PREFIX=login_tokens:
TOKEN_EXPIRE_TIME=-1

# JWT Configuration (for parsing Java JWT Token)
JWT_SECRET=abcdefghijklmnopqrstuvwxyz
JWT_ALGORITHM=HS512

# Auth (Token)
AUTH_ENABLED=true

# Monitoring Configuration
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

